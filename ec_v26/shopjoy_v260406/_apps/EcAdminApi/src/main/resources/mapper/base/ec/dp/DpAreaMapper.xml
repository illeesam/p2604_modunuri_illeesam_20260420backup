<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.dp.mapper.DpAreaMapper">

    <!-- 전시 영역 조회 조건 -->
    <sql id="dpAreaCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND a.site_id = #{p.siteId}</if>
            <if test="p.typeCd != null and p.typeCd != ''">AND a.area_type_cd = #{p.typeCd}</if>
            <if test="p.kw != null and p.kw != ''">
                AND (a.area_nm ILIKE '%' || #{p.kw} || '%')
            </if>
            <if test="p.dateStart != null and p.dateStart != ''">AND a.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND a.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 전시 영역 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.dp.data.dto.DpAreaDto">
        SELECT
            a.*,
            ui.ui_nm AS ui_nm,
            ste.site_nm AS site_nm
        FROM dp_area a
            LEFT JOIN dp_ui ui ON ui.ui_id = a.ui_id
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
        WHERE a.area_id = #{id}
    </select>

    <!-- 전시 영역 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.dp.data.dto.DpAreaDto">
        SELECT
            a.*,
            ui.ui_nm AS ui_nm,
            ste.site_nm AS site_nm
        FROM dp_area a
            LEFT JOIN dp_ui ui ON ui.ui_id = a.ui_id
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
            <include refid="dpAreaCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY a.area_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY a.area_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY a.area_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY a.area_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY a.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY a.reg_date DESC</when>
            <otherwise>ORDER BY a.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 전시 영역 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.dp.data.dto.DpAreaDto">
        SELECT
            a.*,
            ui.ui_nm AS ui_nm,
            ste.site_nm AS site_nm
        FROM dp_area a
            LEFT JOIN dp_ui ui ON ui.ui_id = a.ui_id
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
            <include refid="dpAreaCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY a.area_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY a.area_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY a.area_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY a.area_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY a.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY a.reg_date DESC</when>
            <otherwise>ORDER BY a.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 전시 영역 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM dp_area a
            <include refid="dpAreaCond"/>
    </select>

    <!-- 전시 영역 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.dp.data.entity.DpArea">
        UPDATE dp_area
        <set>
            <if test="uiId != null">ui_id = #{uiId},</if>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="areaCd != null">area_cd = #{areaCd},</if>
            <if test="areaNm != null">area_nm = #{areaNm},</if>
            <if test="areaTypeCd != null">area_type_cd = #{areaTypeCd},</if>
            <if test="areaDesc != null">area_desc = #{areaDesc},</if>
            <if test="dispPath != null">disp_path = #{dispPath},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="useStartDate != null">use_start_date = #{useStartDate},</if>
            <if test="useEndDate != null">use_end_date = #{useEndDate},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE area_id = #{areaId}
    </update>

</mapper>
