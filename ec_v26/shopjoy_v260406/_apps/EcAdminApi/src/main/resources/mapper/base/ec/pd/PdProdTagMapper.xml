<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.pd.mapper.PdProdTagMapper">

    <!-- 상품 태그 조회 조건 -->
    <sql id="pdProdTagCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND t.site_id = #{p.siteId}</if>
            <if test="p.dateStart != null and p.dateStart != ''">AND t.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND t.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 상품 태그 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdProdTagDto">
        SELECT
            t.*,
            prd.prod_nm AS prod_nm,
            ste.site_nm AS site_nm
        FROM pd_prod_tag t
            LEFT JOIN pd_prod prd ON prd.prod_id = t.prod_id
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
        WHERE t.prod_tag_id = #{id}
    </select>

    <!-- 상품 태그 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdProdTagDto">
        SELECT
            t.*,
            prd.prod_nm AS prod_nm,
            ste.site_nm AS site_nm
        FROM pd_prod_tag t
            LEFT JOIN pd_prod prd ON prd.prod_id = t.prod_id
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
            <include refid="pdProdTagCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY t.prod_tag_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY t.prod_tag_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY t.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY t.reg_date DESC</when>
            <otherwise>ORDER BY t.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 상품 태그 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdProdTagDto">
        SELECT
            t.*,
            prd.prod_nm AS prod_nm,
            ste.site_nm AS site_nm
        FROM pd_prod_tag t
            LEFT JOIN pd_prod prd ON prd.prod_id = t.prod_id
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
            <include refid="pdProdTagCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY t.prod_tag_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY t.prod_tag_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY t.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY t.reg_date DESC</when>
            <otherwise>ORDER BY t.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 상품 태그 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM pd_prod_tag t
            <include refid="pdProdTagCond"/>
    </select>

    <!-- 상품 태그 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.pd.data.entity.PdProdTag">
        UPDATE pd_prod_tag
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="prodId != null">prod_id = #{prodId},</if>
            <if test="tagId != null">tag_id = #{tagId},</if>
        </set>
        WHERE prod_tag_id = #{prodTagId}
    </update>

</mapper>
