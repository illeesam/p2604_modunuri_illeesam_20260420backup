<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.autorest.mapper.AutoRestMapper">

    <!-- ============================================================
         공통 WHERE 절 (keyword, 날짜범위, siteId, status, 커스텀 filters)
         ============================================================ -->
    <sql id="commonWhere">
        <where>
            <if test="p.kw != null and p.kw != ''">
                AND (
                <foreach collection="p.searchFields" item="col" separator=" OR ">
                    t.${col}::TEXT ILIKE '%' || #{p.kw} || '%'
                </foreach>
                )
            </if>
            <if test="p.dateStart != null and p.dateStart != ''">
                AND t.${p.dateField} &gt;= #{p.dateStart}::DATE
            </if>
            <if test="p.dateEnd != null and p.dateEnd != ''">
                AND t.${p.dateField} &lt; (#{p.dateEnd}::DATE + INTERVAL '1 day')
            </if>
            <if test="p.siteId != null and p.siteId != ''">
                AND t.site_id = #{p.siteId}
            </if>
            <if test="p.status != null and p.status != ''">
                AND (
                    t.use_yn = #{p.status}
                    OR t.status_cd = #{p.status}
                    OR t.order_status_cd = #{p.status}
                    OR t.member_status_cd = #{p.status}
                    OR t.prod_status_cd = #{p.status}
                    OR t.claim_status_cd = #{p.status}
                    OR t.dliv_status_cd = #{p.status}
                    OR t.settle_status_cd = #{p.status}
                )
            </if>
            <if test="p.filters != null">
                <foreach collection="p.filters.entrySet()" index="col" item="val">
                    <if test="val != null and val != ''">
                        AND t.${col} = #{val}
                    </if>
                </foreach>
            </if>
        </where>
    </sql>

    <!-- ============================================================
         FK 조인 (fkFields: col -> targetTable)
         각 FK는 targetTable 에서 가장 대표적인 이름 컬럼을 가져옴
         ============================================================ -->
    <sql id="fkJoins">
        <if test="p.fkFields != null">
            <foreach collection="p.fkFields.entrySet()" index="fkCol" item="targetTable">
                LEFT JOIN ${p.schema}.${targetTable} fk_${fkCol}
                    ON fk_${fkCol}.<![CDATA[
                ]]>${targetTable.replaceAll('^\\w+_', '')}_id = t.${fkCol}
            </foreach>
        </if>
    </sql>

    <!-- ============================================================
         목록 조회 (전체, limit 1000)
         ============================================================ -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.autorest.data.dto.RowMap">
        SELECT t.*
        FROM ${p.schema}.${p.table} t
        <include refid="commonWhere"/>
        <choose>
            <when test="p.orderBy != null and p.orderBy != ''">
                ORDER BY ${p.orderBy}
            </when>
            <otherwise>
                ORDER BY t.${p.pk} DESC
            </otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- ============================================================
         페이지 조회
         ============================================================ -->
    <select id="selectPage" resultType="com.shopjoy.ecadminapi.autorest.data.dto.RowMap">
        SELECT t.*
        FROM ${p.schema}.${p.table} t
        <include refid="commonWhere"/>
        <choose>
            <when test="p.orderBy != null and p.orderBy != ''">
                ORDER BY ${p.orderBy}
            </when>
            <otherwise>
                ORDER BY t.${p.pk} DESC
            </otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- ============================================================
         건수 조회
         ============================================================ -->
    <select id="selectCount" resultType="long">
        SELECT COUNT(*)
        FROM ${p.schema}.${p.table} t
        <include refid="commonWhere"/>
    </select>

    <!-- ============================================================
         단건 조회
         ============================================================ -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.autorest.data.dto.RowMap">
        SELECT t.*
        FROM ${p.schema}.${p.table} t
        WHERE t.${p.pk} = #{p.id}
    </select>

    <!-- ============================================================
         자식 테이블 조회 (getById 에서 childTables 처리)
         ============================================================ -->
    <select id="selectChildren" resultType="com.shopjoy.ecadminapi.autorest.data.dto.RowMap">
        SELECT *
        FROM ${p.schema}.${p.table}
        WHERE ${p.fkCol} = #{p.fkVal}
        ORDER BY ${p.pk} ASC
    </select>

    <!-- ============================================================
         공통코드 라벨 조회 (cdFields 처리용)
         ============================================================ -->
    <select id="selectCodeLabels" resultType="com.shopjoy.ecadminapi.autorest.data.dto.RowMap">
        SELECT code_value, code_label
        FROM sy_code c
        JOIN sy_code_grp g ON g.code_grp_id = c.code_grp_id
        WHERE g.code_grp = #{codeGrp}
          AND c.use_yn = 'Y'
          AND g.use_yn = 'Y'
        <if test="siteId != null and siteId != ''">
            AND (g.site_id IS NULL OR g.site_id = #{siteId})
        </if>
        ORDER BY c.sort_ord ASC
    </select>

</mapper>
