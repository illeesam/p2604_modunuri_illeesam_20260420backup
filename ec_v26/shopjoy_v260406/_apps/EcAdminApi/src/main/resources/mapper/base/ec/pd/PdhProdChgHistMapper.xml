<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.pd.mapper.PdhProdChgHistMapper">

    <!-- 상품 변경 이력 조회 조건 -->
    <sql id="pdhProdChgHistCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND h.site_id = #{p.siteId}</if>
            <if test="p.typeCd != null and p.typeCd != ''">AND h.chg_type_cd = #{p.typeCd}</if>
            <if test="p.dateStart != null and p.dateStart != ''">AND h.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND h.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 상품 변경 이력 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdhProdChgHistDto">
        SELECT
            h.*,
            ste.site_nm AS site_nm
        FROM pdh_prod_chg_hist h
            LEFT JOIN sy_site ste ON ste.site_id = h.site_id
        WHERE h.prod_chg_hist_id = #{id}
    </select>

    <!-- 상품 변경 이력 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdhProdChgHistDto">
        SELECT
            h.*,
            ste.site_nm AS site_nm
        FROM pdh_prod_chg_hist h
            LEFT JOIN sy_site ste ON ste.site_id = h.site_id
            <include refid="pdhProdChgHistCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY h.prod_chg_hist_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY h.prod_chg_hist_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY h.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY h.reg_date DESC</when>
            <otherwise>ORDER BY h.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 상품 변경 이력 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdhProdChgHistDto">
        SELECT
            h.*,
            ste.site_nm AS site_nm
        FROM pdh_prod_chg_hist h
            LEFT JOIN sy_site ste ON ste.site_id = h.site_id
            <include refid="pdhProdChgHistCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY h.prod_chg_hist_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY h.prod_chg_hist_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY h.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY h.reg_date DESC</when>
            <otherwise>ORDER BY h.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 상품 변경 이력 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM pdh_prod_chg_hist h
            <include refid="pdhProdChgHistCond"/>
    </select>

</mapper>
