<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.cm.mapper.CmBltnCateMapper">

    <!-- 게시판 카테고리 조회 조건 -->
    <sql id="cmBltnCateCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND c.site_id = #{p.siteId}</if>
            <if test="p.kw != null and p.kw != ''">
                AND (c.blog_cate_nm ILIKE '%' || #{p.kw} || '%')
            </if>
            <if test="p.dateStart != null and p.dateStart != ''">AND c.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND c.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 게시판 카테고리 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBltnCateDto">
        SELECT
            c.*,
            ste.site_nm AS site_nm
        FROM cm_bltn_cate c
            LEFT JOIN sy_site ste ON ste.site_id = c.site_id
        WHERE c.blog_cate_id = #{id}
    </select>

    <!-- 게시판 카테고리 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBltnCateDto">
        SELECT
            c.*,
            ste.site_nm AS site_nm
        FROM cm_bltn_cate c
            LEFT JOIN sy_site ste ON ste.site_id = c.site_id
            <include refid="cmBltnCateCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY c.blog_cate_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY c.blog_cate_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY c.blog_cate_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY c.blog_cate_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY c.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY c.reg_date DESC</when>
            <otherwise>ORDER BY c.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 게시판 카테고리 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBltnCateDto">
        SELECT
            c.*,
            ste.site_nm AS site_nm
        FROM cm_bltn_cate c
            LEFT JOIN sy_site ste ON ste.site_id = c.site_id
            <include refid="cmBltnCateCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY c.blog_cate_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY c.blog_cate_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY c.blog_cate_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY c.blog_cate_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY c.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY c.reg_date DESC</when>
            <otherwise>ORDER BY c.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 게시판 카테고리 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM cm_bltn_cate c
            <include refid="cmBltnCateCond"/>
    </select>

    <!-- 게시판 카테고리 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.cm.data.entity.CmBltnCate">
        UPDATE cm_bltn_cate
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="blogCateNm != null">blog_cate_nm = #{blogCateNm},</if>
            <if test="parentBlogCateId != null">parent_blog_cate_id = #{parentBlogCateId},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE blog_cate_id = #{blogCateId}
    </update>

</mapper>
