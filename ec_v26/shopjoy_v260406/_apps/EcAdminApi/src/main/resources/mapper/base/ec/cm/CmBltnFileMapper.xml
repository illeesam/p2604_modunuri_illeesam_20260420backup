<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.cm.mapper.CmBltnFileMapper">

    <!-- 게시물 첨부파일 조회 조건 -->
    <sql id="cmBltnFileCond">
        <where>
            <if test="p.dateStart != null and p.dateStart != ''">AND f.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND f.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 게시물 첨부파일 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBltnFileDto">
        SELECT
            f.*,
            blt.blog_title AS blog_nm
        FROM cm_bltn_file f
            LEFT JOIN cm_bltn blt ON blt.blog_id = f.blog_id
        WHERE f.blog_img_id = #{id}
    </select>

    <!-- 게시물 첨부파일 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBltnFileDto">
        SELECT
            f.*,
            blt.blog_title AS blog_nm
        FROM cm_bltn_file f
            LEFT JOIN cm_bltn blt ON blt.blog_id = f.blog_id
            <include refid="cmBltnFileCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY f.blog_img_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY f.blog_img_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY f.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY f.reg_date DESC</when>
            <otherwise>ORDER BY f.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 게시물 첨부파일 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmBltnFileDto">
        SELECT
            f.*,
            blt.blog_title AS blog_nm
        FROM cm_bltn_file f
            LEFT JOIN cm_bltn blt ON blt.blog_id = f.blog_id
            <include refid="cmBltnFileCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY f.blog_img_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY f.blog_img_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY f.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY f.reg_date DESC</when>
            <otherwise>ORDER BY f.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 게시물 첨부파일 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM cm_bltn_file f
            <include refid="cmBltnFileCond"/>
    </select>

    <!-- 게시물 첨부파일 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.cm.data.entity.CmBltnFile">
        UPDATE cm_bltn_file
        <set>
            <if test="blogId != null">blog_id = #{blogId},</if>
            <if test="imgUrl != null">img_url = #{imgUrl},</if>
            <if test="thumbUrl != null">thumb_url = #{thumbUrl},</if>
            <if test="imgAltText != null">img_alt_text = #{imgAltText},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
        </set>
        WHERE blog_img_id = #{blogImgId}
    </update>

</mapper>
