<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.mb.mapper.MbMemberAddrMapper">

    <!-- 회원 주소 조회 조건 -->
    <sql id="mbMemberAddrCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND a.site_id = #{p.siteId}</if>
            <if test="p.kw != null and p.kw != ''">
                AND (a.addr_nm ILIKE '%' || #{p.kw} || '%'
                  OR a.recv_nm ILIKE '%' || #{p.kw} || '%')
            </if>
            <if test="p.dateStart != null and p.dateStart != ''">AND a.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND a.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 회원 주소 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberAddrDto">
        SELECT
            a.*,
            mem.member_nm AS member_nm,
            ste.site_nm AS site_nm
        FROM mb_member_addr a
            LEFT JOIN mb_member mem ON mem.member_id = a.member_id
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
        WHERE a.addr_id = #{id}
    </select>

    <!-- 회원 주소 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberAddrDto">
        SELECT
            a.*,
            mem.member_nm AS member_nm,
            ste.site_nm AS site_nm
        FROM mb_member_addr a
            LEFT JOIN mb_member mem ON mem.member_id = a.member_id
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
            <include refid="mbMemberAddrCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY a.addr_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY a.addr_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY a.addr_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY a.addr_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY a.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY a.reg_date DESC</when>
            <otherwise>ORDER BY a.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 회원 주소 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberAddrDto">
        SELECT
            a.*,
            mem.member_nm AS member_nm,
            ste.site_nm AS site_nm
        FROM mb_member_addr a
            LEFT JOIN mb_member mem ON mem.member_id = a.member_id
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
            <include refid="mbMemberAddrCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY a.addr_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY a.addr_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY a.addr_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY a.addr_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY a.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY a.reg_date DESC</when>
            <otherwise>ORDER BY a.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 회원 주소 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM mb_member_addr a
            <include refid="mbMemberAddrCond"/>
    </select>

    <!-- 회원 주소 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.mb.data.entity.MbMemberAddr">
        UPDATE mb_member_addr
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="memberId != null">member_id = #{memberId},</if>
            <if test="addrNm != null">addr_nm = #{addrNm},</if>
            <if test="recvNm != null">recv_nm = #{recvNm},</if>
            <if test="recvPhone != null">recv_phone = #{recvPhone},</if>
            <if test="zipCd != null">zip_cd = #{zipCd},</if>
            <if test="addr != null">addr = #{addr},</if>
            <if test="addrDetail != null">addr_detail = #{addrDetail},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE addr_id = #{addrId}
    </update>

</mapper>
