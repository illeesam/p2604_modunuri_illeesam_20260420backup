<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.mb.mapper.MbMemberGroupMapper">

    <!-- 회원 그룹 조회 조건 -->
    <sql id="mbMemberGroupCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND g.site_id = #{p.siteId}</if>
            <if test="p.kw != null and p.kw != ''">
                AND (g.group_nm ILIKE '%' || #{p.kw} || '%')
            </if>
            <if test="p.dateStart != null and p.dateStart != ''">AND g.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND g.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 회원 그룹 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberGroupDto">
        SELECT
            g.*,
            ste.site_nm AS site_nm
        FROM mb_member_group g
            LEFT JOIN sy_site ste ON ste.site_id = g.site_id
        WHERE g.group_id = #{id}
    </select>

    <!-- 회원 그룹 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberGroupDto">
        SELECT
            g.*,
            ste.site_nm AS site_nm
        FROM mb_member_group g
            LEFT JOIN sy_site ste ON ste.site_id = g.site_id
            <include refid="mbMemberGroupCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY g.group_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY g.group_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY g.group_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY g.group_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY g.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY g.reg_date DESC</when>
            <otherwise>ORDER BY g.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 회원 그룹 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.mb.data.dto.MbMemberGroupDto">
        SELECT
            g.*,
            ste.site_nm AS site_nm
        FROM mb_member_group g
            LEFT JOIN sy_site ste ON ste.site_id = g.site_id
            <include refid="mbMemberGroupCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY g.group_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY g.group_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY g.group_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY g.group_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY g.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY g.reg_date DESC</when>
            <otherwise>ORDER BY g.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 회원 그룹 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM mb_member_group g
            <include refid="mbMemberGroupCond"/>
    </select>

    <!-- 회원 그룹 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.mb.data.entity.MbMemberGroup">
        UPDATE mb_member_group
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="groupNm != null">group_nm = #{groupNm},</if>
            <if test="groupMemo != null">group_memo = #{groupMemo},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE group_id = #{groupId}
    </update>

</mapper>
