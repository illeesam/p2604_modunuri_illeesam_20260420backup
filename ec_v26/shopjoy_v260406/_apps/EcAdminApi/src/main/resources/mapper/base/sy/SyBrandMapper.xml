<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.sy.mapper.SyBrandMapper">

    <!-- 브랜드 조회 조건 -->
    <sql id="syBrandCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND b.site_id = #{p.siteId}</if>
            <if test="p.vendorId != null and p.vendorId != ''">AND b.vendor_id = #{p.vendorId}</if>
            <if test="p.kw != null and p.kw != ''">
                AND (b.brand_nm ILIKE '%' || #{p.kw} || '%'
                  OR b.brand_en_nm ILIKE '%' || #{p.kw} || '%')
            </if>
            <if test="p.dateStart != null and p.dateStart != ''">AND b.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND b.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 브랜드 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyBrandDto">
        SELECT
            b.*,
            ste.site_nm AS site_nm
        FROM sy_brand b
            LEFT JOIN sy_site ste ON ste.site_id = b.site_id
        WHERE b.brand_id = #{id}
    </select>

    <!-- 브랜드 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyBrandDto">
        SELECT
            b.*,
            ste.site_nm AS site_nm
        FROM sy_brand b
            LEFT JOIN sy_site ste ON ste.site_id = b.site_id
            <include refid="syBrandCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY b.brand_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY b.brand_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY b.brand_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY b.brand_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY b.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY b.reg_date DESC</when>
            <otherwise>ORDER BY b.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 브랜드 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyBrandDto">
        SELECT
            b.*,
            ste.site_nm AS site_nm
        FROM sy_brand b
            LEFT JOIN sy_site ste ON ste.site_id = b.site_id
            <include refid="syBrandCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY b.brand_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY b.brand_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY b.brand_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY b.brand_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY b.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY b.reg_date DESC</when>
            <otherwise>ORDER BY b.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 브랜드 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM sy_brand b
            <include refid="syBrandCond"/>
    </select>

    <!-- 브랜드 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.sy.data.entity.SyBrand">
        UPDATE sy_brand
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="brandCode != null">brand_code = #{brandCode},</if>
            <if test="brandNm != null">brand_nm = #{brandNm},</if>
            <if test="brandEnNm != null">brand_en_nm = #{brandEnNm},</if>
            <if test="dispPath != null">disp_path = #{dispPath},</if>
            <if test="logoUrl != null">logo_url = #{logoUrl},</if>
            <if test="vendorId != null">vendor_id = #{vendorId},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="brandRemark != null">brand_remark = #{brandRemark},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE brand_id = #{brandId}
    </update>

</mapper>
