<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.cm.mapper.CmChattMsgMapper">

    <!-- 채팅 메시지 조회 조건 -->
    <sql id="cmChattMsgCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND m.site_id = #{p.siteId}</if>
            <if test="p.dateStart != null and p.dateStart != ''">AND m.send_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND m.send_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 채팅 메시지 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmChattMsgDto">
        SELECT
            m.*,
            ste.site_nm AS site_nm
        FROM cm_chatt_msg m
            LEFT JOIN sy_site ste ON ste.site_id = m.site_id
        WHERE m.msg_id = #{id}
    </select>

    <!-- 채팅 메시지 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmChattMsgDto">
        SELECT
            m.*,
            ste.site_nm AS site_nm
        FROM cm_chatt_msg m
            LEFT JOIN sy_site ste ON ste.site_id = m.site_id
            <include refid="cmChattMsgCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY m.msg_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY m.msg_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY m.send_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY m.send_date DESC</when>
            <otherwise>ORDER BY m.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 채팅 메시지 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.cm.data.dto.CmChattMsgDto">
        SELECT
            m.*,
            ste.site_nm AS site_nm
        FROM cm_chatt_msg m
            LEFT JOIN sy_site ste ON ste.site_id = m.site_id
            <include refid="cmChattMsgCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY m.msg_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY m.msg_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY m.send_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY m.send_date DESC</when>
            <otherwise>ORDER BY m.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 채팅 메시지 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM cm_chatt_msg m
            <include refid="cmChattMsgCond"/>
    </select>

    <!-- 채팅 메시지 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.cm.data.entity.CmChattMsg">
        UPDATE cm_chatt_msg
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="chattId != null">chatt_id = #{chattId},</if>
            <if test="senderCd != null">sender_cd = #{senderCd},</if>
            <if test="msgText != null">msg_text = #{msgText},</if>
            <if test="refType != null">ref_type = #{refType},</if>
            <if test="refId != null">ref_id = #{refId},</if>
            <if test="sendDate != null">send_date = #{sendDate},</if>
            <if test="readYn != null">read_yn = #{readYn},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE msg_id = #{msgId}
    </update>

</mapper>
