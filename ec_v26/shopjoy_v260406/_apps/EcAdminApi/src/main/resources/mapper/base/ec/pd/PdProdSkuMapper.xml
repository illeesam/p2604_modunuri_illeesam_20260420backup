<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.pd.mapper.PdProdSkuMapper">

    <!-- 상품 SKU 조회 조건 -->
    <sql id="pdProdSkuCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND s.site_id = #{p.siteId}</if>
            <if test="p.dateStart != null and p.dateStart != ''">AND s.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND s.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 상품 SKU 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdProdSkuDto">
        SELECT
            s.*,
            ste.site_nm AS site_nm
        FROM pd_prod_sku s
            LEFT JOIN sy_site ste ON ste.site_id = s.site_id
        WHERE s.sku_id = #{id}
    </select>

    <!-- 상품 SKU 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdProdSkuDto">
        SELECT
            s.*,
            ste.site_nm AS site_nm
        FROM pd_prod_sku s
            LEFT JOIN sy_site ste ON ste.site_id = s.site_id
            <include refid="pdProdSkuCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY s.sku_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY s.sku_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY s.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY s.reg_date DESC</when>
            <otherwise>ORDER BY s.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 상품 SKU 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdProdSkuDto">
        SELECT
            s.*,
            ste.site_nm AS site_nm
        FROM pd_prod_sku s
            LEFT JOIN sy_site ste ON ste.site_id = s.site_id
            <include refid="pdProdSkuCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY s.sku_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY s.sku_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY s.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY s.reg_date DESC</when>
            <otherwise>ORDER BY s.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 상품 SKU 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM pd_prod_sku s
            <include refid="pdProdSkuCond"/>
    </select>

    <!-- 상품 SKU 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.pd.data.entity.PdProdSku">
        UPDATE pd_prod_sku
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="prodId != null">prod_id = #{prodId},</if>
            <if test="optItemId1 != null">opt_item_id_1 = #{optItemId1},</if>
            <if test="optItemId2 != null">opt_item_id_2 = #{optItemId2},</if>
            <if test="skuCode != null">sku_code = #{skuCode},</if>
            <if test="addPrice != null">add_price = #{addPrice},</if>
            <if test="prodOptStock != null">prod_opt_stock = #{prodOptStock},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE sku_id = #{skuId}
    </update>

</mapper>
