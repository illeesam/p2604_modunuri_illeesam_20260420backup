<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.sy.mapper.SyAttachMapper">

    <!-- 첨부파일 조회 조건 -->
    <sql id="syAttachCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND a.site_id = #{p.siteId}</if>
            <if test="p.typeCd != null and p.typeCd != ''">AND a.mime_type_cd = #{p.typeCd}</if>
            <if test="p.kw != null and p.kw != ''">
                AND (a.file_nm ILIKE '%' || #{p.kw} || '%'
                  OR a.stored_nm ILIKE '%' || #{p.kw} || '%')
            </if>
            <if test="p.dateStart != null and p.dateStart != ''">AND a.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND a.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 첨부파일 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyAttachDto">
        SELECT
            a.*,
            ste.site_nm AS site_nm
        FROM sy_attach a
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
        WHERE a.attach_id = #{id}
    </select>

    <!-- 첨부파일 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyAttachDto">
        SELECT
            a.*,
            ste.site_nm AS site_nm
        FROM sy_attach a
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
            <include refid="syAttachCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY a.attach_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY a.attach_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY a.file_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY a.file_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY a.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY a.reg_date DESC</when>
            <otherwise>ORDER BY a.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 첨부파일 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyAttachDto">
        SELECT
            a.*,
            ste.site_nm AS site_nm
        FROM sy_attach a
            LEFT JOIN sy_site ste ON ste.site_id = a.site_id
            <include refid="syAttachCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY a.attach_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY a.attach_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY a.file_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY a.file_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY a.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY a.reg_date DESC</when>
            <otherwise>ORDER BY a.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 첨부파일 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM sy_attach a
            <include refid="syAttachCond"/>
    </select>

    <!-- 첨부파일 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.sy.data.entity.SyAttach">
        UPDATE sy_attach
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="attachGrpId != null">attach_grp_id = #{attachGrpId},</if>
            <if test="fileNm != null">file_nm = #{fileNm},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="fileExt != null">file_ext = #{fileExt},</if>
            <if test="mimeTypeCd != null">mime_type_cd = #{mimeTypeCd},</if>
            <if test="storedNm != null">stored_nm = #{storedNm},</if>
            <if test="attachUrl != null">attach_url = #{attachUrl},</if>
            <if test="cdnHost != null">cdn_host = #{cdnHost},</if>
            <if test="cdnImgUrl != null">cdn_img_url = #{cdnImgUrl},</if>
            <if test="cdnThumbUrl != null">cdn_thumb_url = #{cdnThumbUrl},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="attachMemo != null">attach_memo = #{attachMemo},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE attach_id = #{attachId}
    </update>

</mapper>
