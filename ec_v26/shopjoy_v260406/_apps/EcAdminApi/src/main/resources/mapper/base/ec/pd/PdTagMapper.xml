<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.ec.pd.mapper.PdTagMapper">

    <!-- 태그 조회 조건 -->
    <sql id="pdTagCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND t.site_id = #{p.siteId}</if>
            <if test="p.kw != null and p.kw != ''">
                AND (t.tag_nm ILIKE '%' || #{p.kw} || '%')
            </if>
            <if test="p.dateStart != null and p.dateStart != ''">AND t.reg_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND t.reg_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <!-- 태그 상세 조회 -->
    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdTagDto">
        SELECT
            t.*,
            ste.site_nm AS site_nm
        FROM pd_tag t
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
        WHERE t.tag_id = #{id}
    </select>

    <!-- 태그 목록 조회 -->
    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdTagDto">
        SELECT
            t.*,
            ste.site_nm AS site_nm
        FROM pd_tag t
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
            <include refid="pdTagCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY t.tag_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY t.tag_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY t.tag_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY t.tag_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY t.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY t.reg_date DESC</when>
            <otherwise>ORDER BY t.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <!-- 태그 페이징 목록 조회 -->
    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.ec.pd.data.dto.PdTagDto">
        SELECT
            t.*,
            ste.site_nm AS site_nm
        FROM pd_tag t
            LEFT JOIN sy_site ste ON ste.site_id = t.site_id
            <include refid="pdTagCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY t.tag_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY t.tag_id DESC</when>
            <when test="p.sort == 'nm_asc'">ORDER BY t.tag_nm ASC</when>
            <when test="p.sort == 'nm_desc'">ORDER BY t.tag_nm DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY t.reg_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY t.reg_date DESC</when>
            <otherwise>ORDER BY t.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <!-- 태그 전체 건수 조회 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM pd_tag t
            <include refid="pdTagCond"/>
    </select>

    <!-- 태그 선택 필드 수정 -->
    <update id="updateSelective" parameterType="com.shopjoy.ecadminapi.base.ec.pd.data.entity.PdTag">
        UPDATE pd_tag
        <set>
            <if test="siteId != null">site_id = #{siteId},</if>
            <if test="tagNm != null">tag_nm = #{tagNm},</if>
            <if test="tagDesc != null">tag_desc = #{tagDesc},</if>
            <if test="useCount != null">use_count = #{useCount},</if>
            <if test="sortOrd != null">sort_ord = #{sortOrd},</if>
            <if test="useYn != null">use_yn = #{useYn},</if>
            <if test="updBy != null">upd_by = #{updBy},</if>
            <if test="updDate != null">upd_date = #{updDate},</if>
        </set>
        WHERE tag_id = #{tagId}
    </update>

</mapper>
