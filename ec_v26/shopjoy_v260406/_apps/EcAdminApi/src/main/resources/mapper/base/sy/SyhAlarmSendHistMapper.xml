<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopjoy.ecadminapi.base.sy.mapper.SyhAlarmSendHistMapper">

    <sql id="syhAlarmSendHistCond">
        <where>
            <if test="p.siteId != null and p.siteId != ''">AND h.site_id = #{p.siteId}</if>
            <if test="p.status != null and p.status != ''">AND h.send_hist_status_cd = #{p.status}</if>
            <if test="p.dateStart != null and p.dateStart != ''">AND h.send_date &gt;= #{p.dateStart}::DATE</if>
            <if test="p.dateEnd   != null and p.dateEnd   != ''">AND h.send_date &lt;  (#{p.dateEnd}::DATE + INTERVAL '1 day')</if>
        </where>
    </sql>

    <select id="selectById" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyhAlarmSendHistDto">
        SELECT
            h.*,
            ste.site_nm AS site_nm
        FROM syh_alarm_send_hist h
            LEFT JOIN sy_site ste ON ste.site_id = h.site_id
        WHERE h.send_hist_id = #{id}
    </select>

    <select id="selectList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyhAlarmSendHistDto">
        SELECT
            h.*,
            ste.site_nm AS site_nm
        FROM syh_alarm_send_hist h
            LEFT JOIN sy_site ste ON ste.site_id = h.site_id
            <include refid="syhAlarmSendHistCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY h.send_hist_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY h.send_hist_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY h.send_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY h.send_date DESC</when>
            <otherwise>ORDER BY h.reg_date DESC</otherwise>
        </choose>
        <if test="p.limit != null and p.offset != null">LIMIT #{p.limit} OFFSET #{p.offset}</if>
    </select>

    <select id="selectPageList" resultType="com.shopjoy.ecadminapi.base.sy.data.dto.SyhAlarmSendHistDto">
        SELECT
            h.*,
            ste.site_nm AS site_nm
        FROM syh_alarm_send_hist h
            LEFT JOIN sy_site ste ON ste.site_id = h.site_id
            <include refid="syhAlarmSendHistCond"/>
        <choose>
            <when test="p.sort == 'id_asc'">ORDER BY h.send_hist_id ASC</when>
            <when test="p.sort == 'id_desc'">ORDER BY h.send_hist_id DESC</when>
            <when test="p.sort == 'reg_asc'">ORDER BY h.send_date ASC</when>
            <when test="p.sort == 'reg_desc'">ORDER BY h.send_date DESC</when>
            <otherwise>ORDER BY h.reg_date DESC</otherwise>
        </choose>
        LIMIT #{p.limit} OFFSET #{p.offset}
    </select>

    <select id="selectPageCount" resultType="long">
        SELECT COUNT(*)
        FROM syh_alarm_send_hist h
            <include refid="syhAlarmSendHistCond"/>
    </select>

</mapper>
