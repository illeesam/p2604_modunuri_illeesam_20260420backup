<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ================================================================
         공통 속성
         ================================================================ -->
    <property name="APP_NAME"   value="ecadminapi"/>
    <property name="LOG_DIR"    value="logs"/>

    <!-- 콘솔 컬러 패턴 -->
    <conversionRule conversionWord="clr"
                    converterClass="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex"
                    converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>

    <!-- ================================================================
         LOCAL / DEV — 컬러 콘솔, DEBUG
         ================================================================ -->
    <springProfile name="local,dev">

        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%clr(%d{HH:mm:ss.SSS}){faint} %clr(%5level){highlight} %clr([%15.15thread]){faint} %clr(%-45.45logger{40}){cyan} : %msg%n%wex</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- 앱 -->
        <logger name="com.shopjoy.ecadminapi" level="DEBUG"/>

        <!-- MyBatis 인터셉터 결과 로그 (DEBUG) -->
        <logger name="com.shopjoy.ecadminapi.config.MyBatisQueryInterceptor" level="DEBUG"/>

        <!-- P6Spy SQL 로그 -->
        <logger name="p6spy" level="INFO"/>

        <!-- Spring / Hibernate 불필요 로그 억제 -->
        <logger name="org.springframework"          level="WARN"/>
        <logger name="org.hibernate"                level="WARN"/>
        <logger name="org.mybatis"                  level="WARN"/>
        <logger name="com.zaxxer.hikari"            level="WARN"/>
        <logger name="org.apache.catalina"          level="WARN"/>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>

    </springProfile>

    <!-- ================================================================
         PROD — 파일 롤링, WARN
         ================================================================ -->
    <springProfile name="prod">

        <!-- 콘솔 (최소) -->
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5level [%thread] %logger{36} : %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <!-- 롤링 파일 — 일별 + 크기 기반 -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/${APP_NAME}.log</file>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5level [%thread] %logger{50} : %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <!-- 에러 전용 파일 -->
        <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/${APP_NAME}-error.log</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>ERROR</level>
            </filter>
            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5level [%thread] %logger{50} : %msg%n%ex</pattern>
                <charset>UTF-8</charset>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_DIR}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <logger name="com.shopjoy.ecadminapi" level="INFO"/>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="FILE_ERROR"/>
        </root>

    </springProfile>

</configuration>
